          {
            "hasAncestor": "AssaultCarbine"
          },
          {
            "hasAncestor": "MarksmanRifle"
          },
          {
            "hasAncestor": "SniperRifle"
          }
        ]
      },
      "type": "MR_762x51",
      "applyToManualOverrides": true
    },
    {
      "comment": "Group for 9x19PARA SMG weapons",
      "conditions": {
        "caliber": "Caliber9x19PARA",
        "hasAncestor": "Smg"
      },
      "type": "smg_9x19PARA"
    },
    {
      "comment": "Group for VSS weapons",
      "conditions": {
        "nameMatches": "\\b(VSS|Vintorez)\\w*",
        "caliber": "Caliber9x39",
        "or": [
          {
            "hasAncestor": "AssaultCarbine"
          },
          {
            "hasAncestor": "MarksmanRifle"
          }
        ],
        "not": {
          "nameMatches": "(\\b(VSK-94)\\w*)"
        }
      },
      "type": "VSS",
      "applyToManualOverrides": true
    },
    {
      "comment": "Group for only MCX SPEAR weapon variants",
      "conditions": {
        "or": [
          {
            "nameMatches": "\\b(MCX SPEAR|MCX-SPEAR)\\w*"
          },
          {
            "descriptionMatches": "\\b(MCX SPEAR|MCX-SPEAR)\\w*"
          }
        ]
      },
      "type": "mcx_spear",
      "applyToManualOverrides": true
    },
    {
      "comment": "Group for any MCX weapons",
      "conditions": {
        "or": [
          {
            "nameMatches": "\\b(mcx|virtus|MCX-)\\w*"
          },
          {
            "descriptionMatches": "\\b(mcx|virtus|MCX-)\\w*"
          }
        ]
      },
      "type": "mcx_any",
      "applyToManualOverrides": true
    },
    {
      "comment": "Group for any SCAR weapons",
      "conditions": {
        "or": [
          {
            "nameMatches": "\\b(scar)\\w*"
