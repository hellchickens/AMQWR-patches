{
  "version": 2,
  "aliasNameStripWords": [],
  "aliasNameExcludeWeapons": [],
  "overrideBehaviour": "MERGE",
  "canBeUsedAs": {},
  "manualTypeOverrides": {},
  "customTypeRules": [
    {
      "comment": "Group for HK weapons",
      "conditions": {
        "or": [
          {
            "nameMatches": "^(HK)"
          },
          {
            "descriptionMatches": "(HK |Heckler|Koch)"
          }
        ]},
      "type": "HK",
      "applyToManualOverrides": true

    },
    {
      "comment": "Group for SR-25_like weapons",
      "conditions": {
        "and": [
          {
            "or": [
              {
                "nameMatches": "\\b(SR-)\\w*"
              },
              {
                "descriptionMatches": "\\b(SR-)\\w*"
              }
            ]
          },
          {
            "or": [
              {
                "caliber": "Caliber86x43"
              },
              {
                "caliber": "Caliber762x51"
              },
              {
                "caliber": "Caliber6.5x48"
              },
              {
                "caliber": "Caliber68x51"
              }
            ]
          },
          {
            "or": [
              {
                "hasAncestor": "AssaultRifle"
              },
              {
                "hasAncestor": "AssaultCarbine"
              },
              {
                "hasAncestor": "MarksmanRifle"
              },
              {
                "hasAncestor": "SniperRifle"
              }
            ]
          }
        ]
      },
      "type": "SR-25_like",
      "applyToManualOverrides": true
    },
    {
      "comment": "Group for 7.62x54R Bolt-action and DMR weapons",
      "conditions": {
        "caliber": "Caliber762x54R",
        "or": [
          {
            "hasAncestor": "MarksmanRifle"
          },
          {
            "hasAncestor": "SniperRifle"
          },
          {
            "hasAncestor": "BoltActionSniperRifle"
          }
        ]
      },
      "type": "BA_MR_762x54R",
      "applyToManualOverrides": true
    },
    {
      "comment": "Group for 7.62x51 BoltAction weapons",
      "conditions": {
        "caliber": "Caliber762x51",
        "or": [
          {
            "hasAncestor": "BoltActionSniperRifle"
          },
          {
            "hasAncestor": "SniperRifle"
          }
        ]
      },
      "type": "BA_762x51",
      "applyToManualOverrides": true
    },
    {
      "comment": "Group for 7.62x51 DMR weapons",
      "conditions": {
        "caliber": "Caliber762x51",
