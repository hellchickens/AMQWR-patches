                {
                  "descriptionMatches": "(\\b(Minebea)\\w*)"
                }
              ]
            }
          }
        ]
      },
      "type": "russian_smg_pistol",
      "applyToManualOverrides": true
    },
    {
      "comment": "Group for russian shotguns",
      "conditions": {
        "and": [
          {
            "or": [
              {
                "nameMatches": "Russia|Russian|Soviet|MP-|Saiga-12|TOZ"
              },
              {
                "descriptionMatches": "Russia|Russian|Soviet|MP-|Saiga-12|TOZ"
